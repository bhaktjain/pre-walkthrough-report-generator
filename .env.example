# Environment variables for Pre-Walkthrough Report Generator
# Copy this file to .env and fill in your actual values

# Anthropic (Claude) API Key (required) — used for transcript extraction
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Claude model (optional; defaults to claude-opus-4-8)
CLAUDE_MODEL=claude-opus-4-8

# RapidAPI Key for property data (required)
RAPIDAPI_KEY=your_rapidapi_key_here

# SerpAPI Key for web search (optional)
SERPAPI_KEY=your_serpapi_key_here

# Zoho CRM API credentials (required for neighboring projects feature)
ZOHO_CLIENT_ID=your_zoho_client_id_here
ZOHO_CLIENT_SECRET=your_zoho_client_secret_here
ZOHO_REFRESH_TOKEN=your_zoho_refresh_token_here

# Server configuration
PORT=10000
ENVIRONMENT=production

# Logging
LOG_LEVEL=INFO